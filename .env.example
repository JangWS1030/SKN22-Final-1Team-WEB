# Django 기본 설정
DEBUG=True
SECRET_KEY=django-insecure-change-me
TIME_ZONE=Asia/Seoul
ALLOWED_HOSTS=localhost,127.0.0.1

# 데이터베이스
# 로컬 SQLite를 쓸 때는 DATABASE_URL을 비워 두고 LOCAL_DATABASE_URL만 사용하세요.
# Postgres를 쓸 때는 DATABASE_URL 또는 LOCAL_DATABASE_URL 중 하나를 채워도 됩니다.
DATABASE_URL=
LOCAL_DATABASE_URL=sqlite:///db.sqlite3
SUPABASE_USE_REMOTE_DB=False
SUPABASE_DB_URL=

# Redis / 캐시
REDIS_URL=
REDIS_KEY_PREFIX=mirrai
REDIS_USE_FOR_SESSIONS=True
CACHE_DEFAULT_TIMEOUT=300
PARTNER_DASHBOARD_CACHE_SECONDS=30
PARTNER_LIST_CACHE_SECONDS=60
PARTNER_DETAIL_CACHE_SECONDS=45
PARTNER_HISTORY_CACHE_SECONDS=30
PARTNER_LOOKUP_CACHE_SECONDS=45
PARTNER_REPORT_CACHE_SECONDS=90
SESSION_SAVE_EVERY_REQUEST=True
SESSION_ENGINE=django.contrib.sessions.backends.db
SESSION_CACHE_ALIAS=default

# 인증
JWT_SECRET_KEY=replace-with-a-random-secret

# Supabase 스토리지
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_USE_REMOTE_STORAGE=False
SUPABASE_BUCKET=mirrai-assets
SUPABASE_BUCKET_PUBLIC=False
SUPABASE_SIGNED_URL_EXPIRES_IN=3600
SUPABASE_BUCKET_FILE_SIZE_LIMIT=10485760
SUPABASE_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp

# 추천 파이프라인
MIRRAI_LOCAL_MOCK_RESULTS=False
MIRRAI_PERSIST_CAPTURE_IMAGES=False
RUNPOD_BASE_URL=https://api.runpod.ai/v2
RUNPOD_API_KEY=
RUNPOD_ENDPOINT_ID=
MIRRAI_AI_PROVIDER=runpod
MIRRAI_AI_API_VERSION=
MIRRAI_INTERNAL_API_KEY=

# 챗봇
MIRRAI_MODEL_CHATBOT_PROVIDER=openai
MIRRAI_MODEL_CHATBOT_API_KEY=
MIRRAI_MODEL_CHATBOT_URL=
MIRRAI_MODEL_CHATBOT_TIMEOUT=20
MIRRAI_MODEL_CHATBOT_OPENAI_MODEL=gpt-4.1-mini
MIRRAI_MODEL_CHATBOT_FALLBACK_OPENAI_MODEL=
MIRRAI_MODEL_CHATBOT_MAX_OUTPUT_TOKENS=2048
MIRRAI_MODEL_CHATBOT_INCLUDE_SYSTEM_PROMPT=false
MIRRAI_MODEL_CHATBOT_LOCAL_TOP_K=3
MIRRAI_MODEL_CHATBOT_LOCAL_CHUNK_SIZE=900
MIRRAI_MODEL_CHATBOT_LOCAL_CHUNK_OVERLAP=180
MIRRAI_MODEL_CHATBOT_LOCAL_EMBED_DIM=192

# 트렌드 수집 및 스케줄러
GEMINI_API_KEY=
TREND_REFINER_MODEL=gemini-2.5-flash
TREND_REFRESH_ENABLED=False
TREND_REFRESH_INTERVAL_MINUTES=0
TREND_REFRESH_SOURCE=ai_repo_refresh_trends
TREND_REFRESH_SOURCES=
ENABLE_TREND_SCHEDULER=False
TREND_SCHEDULER_TIMEZONE=Asia/Seoul
TREND_SCHEDULER_WEEKLY_DAY=fri
TREND_SCHEDULER_WEEKLY_HOUR=8
TREND_SCHEDULER_WEEKLY_MINUTE=0
TREND_SCHEDULER_STEPS=crawl,refine,llm_refine,vectorize,rebuild_ncs,rebuild_styles
TREND_SCHEDULER_INCLUDE_NCS=False
TREND_SCHEDULER_INCLUDE_STYLES=False
TREND_SCHEDULER_TIMEOUT=1800
TREND_SCHEDULER_POLL_INTERVAL=5
TREND_SCHEDULER_SLEEP_INTERVAL=15
TREND_SCHEDULER_TEST_AT=

# 최신 트렌드 피드
TREND_LATEST_REMOTE_ENABLED=False
TREND_LATEST_RUNPOD_TIMEOUT=8
TREND_LATEST_RUNPOD_POLL_INTERVAL=2

# 워터마크 및 이미지 자산
MIRRAI_WATERMARK_IMAGE=static/branding/mirrai_wordmark_primary.png
MIRRAI_WATERMARK_OPACITY=0.15
MIRRAI_WATERMARK_ANGLE=-32.0
MIRRAI_WATERMARK_WIDTH_RATIO=0.34
MIRRAI_WATERMARK_SPACING_X_RATIO=0.38
MIRRAI_WATERMARK_SPACING_Y_RATIO=1.2
MIRRAI_WATERMARK_STAGGER_RATIO=0.48

# 프론트엔드
PORT=3000
